  m_Script: {fileID: 11500000, guid: d09215242c7c64f89a0c270c903d53fd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterConversationManager
  characterCommentText: {fileID: 811075359}
  firstComment: "\u6765\u3066\u304F\u308C\u3066\u3042\u308A\u304C\u3068\u3046\u3002\u3088\u308D\u3057\u304F\u983C\u3080\u3088\u3002\u2026\u307E\u3055\u304B\u30E1\u30C3\u30BB\u30FC\u30B8\u304C\u6D88\u3048\u308B\u3068\u306F\u601D\u308F\u306A\u304F\u3066\u306D"
  answer1: "18\u664210\u5206\u306B\u30E1\u30C3\u30BB\u30FC\u30B8\u9001\u3063\u3066\u3001\u4F1A\u8B70\u5BA46\u3067\u305A\u3063\u3068\u4F5C\u696D\u3057\u3066\u305F\u300218\u664230\u5206\u306B\u30E1\u30C3\u30BB\u30FC\u30B8\u6D88\u3048\u3066\u308B\u306E\u306B\u6C17\u3065\u3044\u3066\u9752\u3056\u3081\u305F\u3088"
  answer2: "\u3082\u3061\u308D\u3093\u77E5\u3063\u3066\u308B\u3001\u79C1\u304C\u9001\u3063\u305F\u304B\u3089\u306D\u3002\n\u300E\u6765\u6708\u3001\u5168\u793E\u54E1\u3067\u30A4\u30F3\u30C9\u3078\u793E\u54E1\u65C5\u884C\u306B\u884C\u304D\u307E\u3059\u3002\u884C\u304D\u5148\u306F\u30D0\u30E9\u30CA\u30B7\u3002\u30AC\u30F3\u30B8\u30B9\u5DDD\u3067\u306E\u6C90\u6D74\u4F53\u9A13\u3068\u3001\u73FE\u5730IT\u30B9\u30BF\u30FC\u30C8\u30A2\u30C3\u30D7\u3068\u306E\u4EA4\u6D41\u4F1A\u3092\u4E88\u5B9A\u3057\u3066\u3044\u307E\u3059\u300F\u3063\u3066\u5185\u5BB9\u3060"
  answer3: "\u4F1A\u8B70\u5BA4\u306B\u3053\u3082\u3063\u3066\u305F\u304B\u3089\u8AB0\u3082\u898B\u3066\u306A\u3044\u3093\u3060\u3002\u3059\u307E\u306A\u3044\u306D"
  answer4: "\u6B63\u76F4\u3001\u60AA\u610F\u306E\u3042\u308B\u4EBA\u304C\u3084\u3063\u305F\u3068\u306F\u601D\u3044\u305F\u304F\u306A\u3044\u3002\u4F55\u304B\u4E8B\u60C5\u304C\u3042\u3063\u305F\u3093\u3058\u3083\u306A\u3044\u304B\u306A\u3002\u6012\u308B\u3064\u3082\u308A\u306F\u306A\u3044\u3093\u3060"
