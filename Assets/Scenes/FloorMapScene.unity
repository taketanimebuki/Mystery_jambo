  characterCommentText: {fileID: 1596908256}
  firstComment: "\u304A\u75B2\u308C\u3055\u307E\u3067\u3059\u30FC\uFF01\u30A4\u30F3\u30C9\u306E\u8A71\u3067\u3059\u3088\u306D\uFF1F\u3059\u3054\u304F\u306A\u3044\u3067\u3059\u304B\uFF01\uFF1F"
  answer1: "\u4F1A\u8B70\u5BA44\u3067\u30AF\u30E9\u30A4\u30A2\u30F3\u30C8\u8CC7\u6599\u4F5C\u3063\u3066\u307E\u3057\u305F\u300218\u6642\u524D\u304B\u308919\u6642\u307E\u3067"
  answer2: "\u898B\u307E\u3057\u305F\u898B\u307E\u3057\u305F\uFF01\u300E\u6765\u6708\u3001\u5168\u793E\u54E1\u3067\u30A4\u30F3\u30C9\u3078\u793E\u54E1\u65C5\u884C\u306B\u884C\u304D\u307E\u3059\uFF01\u30D0\u30E9\u30CA\u30B7\u3067\u3059\uFF01\u300F\u3063\u3066\u66F8\u3044\u3066\u3042\u308A\u307E\u3057\u305F\u3088\u3002\u30AC\u30F3\u30B8\u30B9\u5DDD\u3067\u6C90\u6D74\u3063\u3066\u66F8\u3044\u3066\u3042\u3063\u3066\u7B11\u3063\u3061\u3083\u3044\u307E\u3057\u305F"
  answer3: "\u4F1A\u8B70\u5BA4\u306B\u3044\u305F\u306E\u3067\u2026\u3042\u3001\u3067\u3082\u4EE3\u8868\u304C\u4F1A\u8B70\u5BA46\u306B\u5165\u3063\u3066\u3044\u304F\u306E\u306F\u5ECA\u4E0B\u3067\u3061\u3089\u3063\u3068\u898B\u307E\u3057\u305F"
  answer4: "\u3046\u30FC\u3093\u3001\u308F\u304B\u3093\u306A\u3044\u306A\u3041\u3002\u3067\u3082\u4EE3\u8868\u3058\u3083\u306A\u3044\u3067\u3059\u3088\u3001\u81EA\u5206\u3067\u9001\u3063\u305F\u3084\u3064\u3060\u3057"
