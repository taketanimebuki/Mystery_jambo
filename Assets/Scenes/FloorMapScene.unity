  firstComment: "\u3042\u3001\u304A\u75B2\u308C\u3055\u307E\u2026\u306A\u306B\uFF1F\u8ABF\u67FB\uFF1F"
  answer1: "\u305A\u3063\u3068\u81EA\u5E2D\u3067\u4F5C\u696D\u3057\u3066\u305F\u300219\u6642\u304F\u3089\u3044\u306B\u5E30\u308D\u3046\u3068\u601D\u3063\u3066\u3066"
  answer2: "\u901A\u77E5\u306F\u6765\u3066\u305F\u3051\u3069\u3001\u5FD9\u3057\u304F\u3066\u958B\u3044\u3066\u306A\u3044\u3093\u3060\u3088\u306D\u3002\u30A4\u30F3\u30C9\u65C5\u884C\uFF1F\u3063\u3066\u5F8C\u3067\u805E\u3044\u3066\u30D3\u30C3\u30AF\u30EA\u3057\u305F"
  answer3: "\u30D5\u30ED\u30A2\u306B\u4EBA\u5C11\u306A\u304B\u3063\u305F\u304B\u306A\u2026F\u3055\u3093\u304C\u30BD\u30EF\u30BD\u30EF\u3057\u3066\u305F\u306E\u306F\u898B\u305F\u304B\u3082"
  answer4: "\u3046\u30FC\u3093\u3001F\u3055\u3093\u304B\u306A\u3041\u2026\u843D\u3061\u7740\u304D\u306A\u304B\u3063\u305F\u3057"
