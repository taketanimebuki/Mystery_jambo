  characterCommentText: {fileID: 1399094447}
  firstComment: "\u304A\u3001\u8ABF\u67FB\u306E\u4EBA\uFF1F\u5354\u529B\u3059\u308B\u3088\u301C\u3002\n\u30A4\u30F3\u30C9\u65C5\u884C\u30DE\u30B8\u304B\u2026\u3063\u3066\u611F\u3058\u3060\u3088\u306D"
  answer1: "18\u664215\u5206\u304F\u3089\u3044\u307E\u3067\u30D5\u30ED\u30A2\u3067\u4F5C\u696D\u3057\u3066\u3001\u305D\u308C\u304B\u3089\u4F1A\u8B70\u5BA43\u3067\u8CC7\u6599\u307E\u3068\u3081\u3066\u305F"
  answer2: "\u901A\u77E5\u306F\u898B\u305F\u3088\u3002\u30A4\u30F3\u30C9\u793E\u54E1\u65C5\u884C\u3063\u3066\u3084\u3064\u3067\u3057\u3087\uFF1F\u30D0\u30E9\u30CA\u30B7\uFF1F\u307F\u305F\u3044\u306A"
  answer3: "\u30D5\u30ED\u30A2\u51FA\u308B\u3068\u304D\u3001A\u3055\u3093\u304C\u81EA\u5E2D\u306B\u3044\u305F\u306E\u306F\u898B\u305F\u3002\u30B9\u30DE\u30DB\u304BPC\u304B\u3001\u4F55\u304B\u771F\u5263\u306B\u898B\u3066\u305F\u306A"
  answer4: "\u3046\u30FC\u3093\u2026\u4EE3\u8868\u304C\u81EA\u5206\u3067\u6D88\u3057\u305F\u3093\u3058\u3083\u306A\u3044\u306E\uFF1F\u3084\u3063\u3071\u30A4\u30F3\u30C9\u7121\u7406\u3060\u308F\u3063\u3066\u306A\u3063\u3066"
