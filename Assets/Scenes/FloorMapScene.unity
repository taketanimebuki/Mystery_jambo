  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterConversationManager
  characterCommentText: {fileID: 58988185}
  firstComment: "\u3042\u3042\u3001\u8ABF\u67FB\u306D\u3002\u5354\u529B\u3059\u308B\u3088\u3002\u6C17\u306B\u306A\u308B\u3053\u3068\u3042\u308B\u3093\u3060"
  answer1: "\u4F1A\u8B70\u5BA42\u3067\u6B8B\u696D\u3057\u3066\u305F\u300218\u664220\u5206\u304F\u3089\u3044\u306B\u98F2\u307F\u7269\u53D6\u308A\u306B\u30D5\u30ED\u30A2\u623B\u3063\u305F\u3093\u3060\u3088\u306D"
  answer2: "\u623B\u308B\u9014\u4E2D\u3067\u901A\u77E5\u898B\u305F\u3088\u3002\u30A4\u30F3\u30C9\u65C5\u884C\u306E\u3084\u3064\u3002\u3067\u3082\u958B\u3053\u3046\u3068\u3057\u305F\u3089\u3082\u3046\u6D88\u3048\u3066\u305F\u3002\u3042\u308C\uFF1F\u3063\u3066\u601D\u3063\u305F"
  answer3: "\u30D5\u30ED\u30A2\u623B\u3063\u305F\u3068\u304D\u3001A\u3055\u3093\u304C\u81EA\u5E2D\u3067\u30B9\u30DE\u30DB\u898B\u3066\u56FA\u307E\u3063\u3066\u305F\u3093\u3060\u3088\u3002\u9854\u8272\u3082\u60AA\u304B\u3063\u305F\u3002\u306A\u3093\u304B\u69D8\u5B50\u5909\u3060\u3063\u305F\u306A\u2026"
  answer4: "A\u3055\u3093\u3001\u3042\u306E\u3068\u304D\u30DE\u30B8\u3067\u9854\u771F\u3063\u9752\u3060\u3063\u305F\u3088\u2026\u8003\u3048\u3059\u304E\u304B\u3082\u3060\u3051\u3069"
