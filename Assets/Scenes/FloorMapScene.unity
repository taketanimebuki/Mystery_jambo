  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterConversationManager
  characterCommentText: {fileID: 2007014898}
  firstComment: "\u3042\u3001\u304A\u75B2\u308C\u3055\u307E\u3067\u3059\u3002\u3055\u3063\u304D\u307E\u3067\u96FB\u8A71\u3067\u3061\u3087\u3063\u3068\u30D0\u30BF\u30D0\u30BF\u3057\u3066\u3066"
  answer1: "18\u6642\u904E\u304E\u304B\u3089\u30C6\u30E9\u30B9\u3067\u96FB\u8A71\u4F1A\u8B70\u3057\u3066\u307E\u3057\u305F\u3002\u30AF\u30E9\u30A4\u30A2\u30F3\u30C8\u306830\u5206\u304F\u3089\u3044"
  answer2: "\u96FB\u8A71\u3057\u3066\u305F\u304B\u3089\u901A\u77E5\u898B\u308C\u3066\u306A\u304F\u3066\u2026\u7D42\u308F\u3063\u3066\u304B\u3089\u898B\u305F\u3089\u3082\u3046\u524A\u9664\u3055\u308C\u3066\u307E\u3057\u305F"
  answer3: "\u30C6\u30E9\u30B9\u304B\u3089\u30D5\u30ED\u30A2\u3061\u3087\u3063\u3068\u898B\u3048\u308B\u3093\u3067\u3059\u3051\u3069\u3001A\u3055\u3093\u304C\u305A\u3063\u3068\u81EA\u5E2D\u306B\u3044\u305F\u306E\u306F\u898B\u3048\u307E\u3057\u305F\u300218\u664220\u5206\u9803\u304B\u306A\u3001\u30B9\u30DE\u30DB\u3092\u3058\u3063\u3068\u898B\u3066\u307E\u3057\u305F\u3088"
  answer4: "F\u3055\u3093\u304C\u30BD\u30EF\u30BD\u30EF\u3057\u3066\u305F\u306E\u306F\u898B\u307E\u3057\u305F\u3051\u3069\u2026\u3067\u3082\u65AD\u5B9A\u306F\u3067\u304D\u306A\u3044\u3067\u3059\u306D\u3002A\u3055\u3093\u3082\u4F55\u304B\u8003\u3048\u8FBC\u3093\u3067\u305F\u3057"
