  m_Script: {fileID: 11500000, guid: d09215242c7c64f89a0c270c903d53fd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterConversationManager
  characterCommentText: {fileID: 1809058716}
  firstComment: "\u304A\u75B2\u308C\u3055\u307E\u3067\u3059\u3002\u843D\u3061\u7740\u3044\u3066\u805E\u304D\u307E\u3059\u306D"
  answer1: "\u4F1A\u8B70\u5BA45\u3067\u8A55\u4FA1\u9762\u8AC7\u306E\u8CC7\u6599\u4F5C\u3063\u3066\u307E\u3057\u305F\u300218\u6642\u304B\u308919\u6642\u307E\u3067"
  answer2: "\u30A4\u30F3\u30C9\u65C5\u884C\u3067\u3059\u3088\u306D\u3002\u5B9F\u306F\u4E8B\u524D\u306B\u4EE3\u8868\u304B\u3089\u76F8\u8AC7\u3092\u53D7\u3051\u3066\u307E\u3057\u305F\u3002\u793E\u54E1\u306E\u30EA\u30A2\u30AF\u30B7\u30E7\u30F3\u304C\u5FC3\u914D\u3060\u3063\u3066"
  answer3: "\u4F1A\u8B70\u5BA4\u51FA\u305F\u3068\u304D\u3001A\u3055\u3093\u304C\u30D5\u30ED\u30A2\u3067\u9752\u3044\u9854\u3057\u3066\u30B9\u30DE\u30DB\u898B\u3066\u305F\u306E\u304C\u6C17\u306B\u306A\u308A\u307E\u3057\u305F\u300218\u664223\u5206\u304F\u3089\u3044\u3060\u3063\u305F\u304B\u306A"
  answer4: "\u4EBA\u3092\u7591\u3046\u306E\u306F\u597D\u304D\u3058\u3083\u306A\u3044\u3067\u3059\u3051\u3069\u2026A\u3055\u3093\u3001\u6700\u8FD1\u30A4\u30F3\u30C9\u306E\u8A71\u984C\u3092\u51FA\u3059\u3068\u9854\u304C\u3053\u308F\u3070\u3063\u3066\u305F\u3093\u3067\u3059\u3088\u306D\u3002\u5065\u5EB7\u8A3A\u65AD\u3067\u3082\u304A\u8179\u5F31\u3044\u3063\u3066\u8A00\u3063\u3066\u305F\u3057\u2026"
