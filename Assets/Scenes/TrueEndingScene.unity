  messages:
  - "\u2026\u2026\u306F\u3041\u301C\u3001\u306A\u3093\u3060\u3001\u305D\u3093\u306A\u3053\u3068\u304B\u3041"
  - "\u8AA4\u64CD\u4F5C\u306F\u8AB0\u306B\u3067\u3082\u3042\u308B\u3088\u3002\u4FFA\u3082\u6614\u3001\u304A\u5BA2\u69D8\u3078\u306E\u8ACB\u6C42\u66F8\u30923\u56DE\u9001\u308A\u3064\u3051\u305F\u3053\u3068\u304C\u3042\u308B"
  - "\u3067\u3001\u30A4\u30F3\u30C9\u304C\u4E0D\u5B89\u3060\u3063\u3066\u3053\u3068\u3082\u3001\u3061\u3083\u3093\u3068\u8A00\u3063\u3066\u304F\u308C\u3066\u3088\u304B\u3063\u305F\u3002\u3080\u3057\u308D\u52A9\u304B\u308B\u3088"
  - "\u793E\u54E1\u65C5\u884C\u306E\u884C\u304D\u5148\u306F\u307F\u3093\u306A\u3067\u8003\u3048\u3088\u3046\u3002\u305D\u3063\u3061\u306E\u65B9\u304C\u307F\u3093\u306A\u697D\u3057\u3081\u308B\uFF01"
