  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TextController
  dialogueText: {fileID: 1351874624}
  messages:
  - ".....\u3054\u3081\u3093\u306A\u3055\u3044\uFF01\uFF01\uFF01"
  - "\u5168\u90E8\u3001\u50D5\u304C\u3084\u308A\u307E\u3057\u305F\u2026\u2026"
  - "\u4F55\u5EA6\u3082\u8AAD\u307F\u8FD4\u3057\u3066\u305F\u3089\u3001\u30B9\u30AF\u30ED\u30FC\u30EB\u3057\u3066\u308B\u3068\u304D\u306B\u9577\u62BC\u3057\u3057\u3061\u3083\u3063\u3066\u2026\u2026\u524A\u9664\u30E1\u30CB\u30E5\u30FC\u304C\u51FA\u3066\u3001\u614C\u3066\u3066\u6D88\u305D\u3046\u3068\u3057\u305F\u3089\u9006\u306B\u62BC\u3057\u3061\u3083\u3063\u3066\u2026\u2026"
  - "\u6C17\u3065\u3044\u305F\u3068\u304D\u306B\u306F\u3082\u3046\u30E1\u30C3\u30BB\u30FC\u30B8\u304C\u6D88\u3048\u3066\u3066\u2026\u2026"
  - "\u3059\u3050\u8A00\u304A\u3046\u3068\u601D\u3063\u305F\u3093\u3067\u3059\u3002\u3067\u3082\u2026\u2026"
  - "\u5B9F\u306F\u50D5\u3001\u304A\u8179\u304C\u3059\u3054\u304F\u5F31\u304F\u3066\u2026\u2026\u6D77\u5916\u65C5\u884C\u3067\u4F55\u5EA6\u304B\u3084\u3089\u304B\u3057\u3066\u3066\u2026\u2026"
  - "\u30A4\u30F3\u30C9\u3063\u3066\u805E\u3044\u305F\u77AC\u9593\u3001\u300E\u7121\u7406\u3060\u2026\u2026\u300F\u3063\u3066\u601D\u3063\u3061\u3083\u3063\u3066\u2026\u2026"
  - "\u3067\u3082\u3001\u307F\u3093\u306A\u304C\u697D\u3057\u307F\u306B\u3057\u3066\u308B\u65C5\u884C\u306E\u304A\u77E5\u3089\u305B\u3092\u3001\u3088\u308A\u306B\u3088\u3063\u3066\u884C\u304D\u305F\u304F\u306A\u3044\u81EA\u5206\u304C\u6D88\u3057\u305F\u3063\u3066\u8A00\u3063\u305F\u3089\u2026\u2026"
  - "\u8A00\u3044\u51FA\u305B\u306A\u304F\u3066...\u672C\u5F53\u306B\u3054\u3081\u3093\u306A\u3055\u3044\uFF01\uFF01"
